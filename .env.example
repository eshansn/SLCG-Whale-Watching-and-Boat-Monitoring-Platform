# Copy this file to .env and replace the example password before starting Compose.
# SQL Server requires at least 8 characters and three of four character classes.
MSSQL_SA_PASSWORD=Replace_With_A_Strong_Password_123!
API_PORT=8080
# At least 32 random bytes. Never commit the real value.
JWT_SIGNING_KEY=Replace_With_At_Least_32_Random_Bytes
# Optional initial administrator. Omit after the account is provisioned.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=Replace_With_A_Strong_Admin_Password_123!
INITIAL_OPS_EMAIL=ops@example.com
INITIAL_OPS_PASSWORD=Replace_With_A_Strong_OPS_Password_123!
